{
  "name": "bulk-pricing-tool",
  "version": "1.2.2",
  "description": "批量导入项目调价工具",
  "author": "chukeru",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/index.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.example.bulkpricingtool",
    "productName": "BulkPricingTool",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mssql": "^10.0.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}